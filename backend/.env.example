# Copy this file to `.env` and fill in real values for your environment.
# Only consumed when DJANGO_SETTINGS_MODULE=config.settings.production;
# local development (config.settings.local) does not read these.

# Set to "False" in production. Never enable DEBUG in production.
DEBUG=False

# A long, random, unpredictable string. Generate with e.g.:
#   uv run python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=changeme

# Postgres connection string, e.g. postgres://user:password@host:5432/dbname
DATABASE_URL=postgres://riser:riser@localhost:5432/riser

# Comma-separated list of hostnames this Django instance may serve.
ALLOWED_HOSTS=riser-backend.onrender.com

# Comma-separated list of allowed frontend origins (scheme + host, no path).
CORS_ALLOWED_ORIGINS=https://riser-frontend.onrender.com

# Anthropic API key for the AI risk-narration briefing (Sprint 02). Get one at
# https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=changeme
